# Deployment mode: "test" | "internal" | "external"
DEPLOYMENT_MODE=test

# Database
DATABASE_URL="file:./data/predictor.db"

# Authentication provider: "sso" | "email"
AUTH_PROVIDER=email

# SSO Configuration (required when AUTH_PROVIDER=sso)
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_ISSUER_URL=

# Email Configuration (required when AUTH_PROVIDER=email)
EMAIL_FROM_ADDRESS=noreply@predictor.example.com
EMAIL_SERVICE_API_KEY=

# Admin emails (comma-separated list of emails with admin access)
ADMIN_EMAILS=admin@example.com

# Session duration in days
SESSION_DURATION_DAYS=7

# Max players per group
MAX_PLAYERS_PER_GROUP=50
